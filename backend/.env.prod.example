# 서버 배포용 환경 파일 (192.168.10.220)
# 복사 후 CHANGE_ME를 실제 값으로 교체:
#   cp backend/.env.prod.example backend/.env.prod
#
# 이 파일은 Git에 커밋하지 마세요 (.gitignore에 .env.prod 포함 확인)

# --- Database ---
DB_HOST=db
DB_PORT=5432
DB_NAME=internal_ai_search
DB_USER=openlink
DB_PASSWORD=CHANGE_ME

DB_PUBLISH_PORT=5434

# --- Ollama (192.168.10.154 개발 PC) ---
OLLAMA_BASE_URL=http://192.168.10.154:11434
OLLAMA_MODEL=gemma3
OLLAMA_TIMEOUT_SECONDS=10
OLLAMA_GENERATE_TIMEOUT_SECONDS=120

# --- Embedding ---
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_TEST_TEXT=사내 지식 검색 시스템 임베딩 테스트 문장입니다.
EMBEDDING_TIMEOUT_SECONDS=20

# --- Auth / app secrets (반드시 변경) ---
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
DATA_SOURCE_SECRET_KEY=CHANGE_ME

# --- Initial admin ---
INITIAL_ADMIN_LOGIN_ID=admin
INITIAL_ADMIN_PASSWORD=CHANGE_ME
INITIAL_ADMIN_NAME=관리자
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_DEPARTMENT=System

# --- WebDAV ---
WEBDAV_TIMEOUT_SECONDS=15

# --- HWP ---
HWP_EXTRACTION_STRATEGY=tiered
HWP5TXT_BIN=hwp5txt
HWP5HTML_BIN=hwp5html
HWP_PARSER_TIMEOUT_SECONDS=120
HWP_MIN_EXTRACTED_TEXT_LENGTH=50
HWP_HTML_MIN_EXTRACTED_TEXT_LENGTH=50
HWP_HTML_MIN_GAIN_RATIO=1.5

# --- Worker ---
WORKER_ENABLED=true
WORKER_ID=prod-worker-1
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_HEARTBEAT_INTERVAL_SECONDS=10
WORKER_STALE_TIMEOUT_MINUTES=30
WORKER_MAX_JOBS_PER_LOOP=1

# --- FULL sync-tree emergency cap ---
SYNC_TREE_EMERGENCY_MAX_ITEMS=0
