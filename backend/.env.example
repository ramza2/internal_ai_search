# Copy to backend/.env and replace CHANGE_ME / placeholders before use.
#   cp backend/.env.example backend/.env
#
# Docker Compose (repo root):
#   docker compose --env-file backend/.env -f docker-compose.dev.yml up -d
#
# Host uvicorn (no Docker): set DB_HOST=localhost, DB_PORT=5434 (or your publish port).
# Do not commit backend/.env with real secrets.

# --- Database ---
# Compose: DB_HOST=db, DB_PORT=5432. Host dev: DB_HOST=localhost, DB_PORT=5434
DB_HOST=db
DB_PORT=5432
DB_NAME=internal_ai_search
DB_USER=openlink
DB_PASSWORD=CHANGE_ME

# Host port for pgAdmin/psql when using compose db (default 5434)
DB_PUBLISH_PORT=5434

# --- Ollama (host; Compose uses host.docker.internal) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3
OLLAMA_TIMEOUT_SECONDS=10
OLLAMA_GENERATE_TIMEOUT_SECONDS=120

# --- Embedding ---
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_TEST_TEXT=사내 지식 검색 시스템 임베딩 테스트 문장입니다.
EMBEDDING_TIMEOUT_SECONDS=20

# --- Auth / app secrets ---
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
DATA_SOURCE_SECRET_KEY=CHANGE_ME

# --- Initial admin (backend startup bootstrap on empty DB) ---
INITIAL_ADMIN_LOGIN_ID=admin
INITIAL_ADMIN_PASSWORD=CHANGE_ME
INITIAL_ADMIN_NAME=Initial Admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_DEPARTMENT=System

# Optional: after change-password (compose E2E / scripts)
# E2E_ADMIN_PASSWORD=<current-admin-password-after-change>
# Used by tools/hwp_poc/hwp_reprocess_api_e2e_verify.py and e2e_compose_verify.py (not INITIAL_ADMIN_PASSWORD).

# --- WebDAV ---
WEBDAV_TIMEOUT_SECONDS=15

# --- HWP (AGPL — legal review not complete) ---
# Extraction: tiered (default) | hwp5txt_only | hwp5html_only
HWP_EXTRACTION_STRATEGY=tiered
HWP5TXT_BIN=hwp5txt
HWP5HTML_BIN=hwp5html
HWP_PARSER_TIMEOUT_SECONDS=120
HWP_MIN_EXTRACTED_TEXT_LENGTH=50
HWP_HTML_MIN_EXTRACTED_TEXT_LENGTH=50
HWP_HTML_MIN_GAIN_RATIO=1.5

# --- DB polling worker (python -m app.worker_main) ---
WORKER_ENABLED=false
WORKER_ID=local-worker-1
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_HEARTBEAT_INTERVAL_SECONDS=10
WORKER_STALE_TIMEOUT_MINUTES=30
WORKER_MAX_JOBS_PER_LOOP=1

# --- FULL sync-tree emergency cap (0 = none; worker/pipeline only) ---
SYNC_TREE_EMERGENCY_MAX_ITEMS=0
