# Copy to `.env` and adjust. See README for full application variables.

# --- DB polling worker (skeleton; `python -m app.worker_main`) ---------------
# FastAPI does not auto-start the worker. CLI runs even when WORKER_ENABLED=false.
WORKER_ENABLED=false
WORKER_ID=local-worker-1
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_HEARTBEAT_INTERVAL_SECONDS=10
WORKER_STALE_TIMEOUT_MINUTES=30
WORKER_MAX_JOBS_PER_LOOP=1

# --- HWP binary parser (hwp5txt / pyhwp; AGPLv3+ — see backend/README) ---
HWP5TXT_BIN=hwp5txt
HWP_PARSER_TIMEOUT_SECONDS=120
HWP_MIN_EXTRACTED_TEXT_LENGTH=50
