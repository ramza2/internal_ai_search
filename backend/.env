SERVICE_NAME=internal-ai-search-backend

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3
# Health-probe timeout (GET /health/llm). Keep short so the probe fails fast.
OLLAMA_TIMEOUT_SECONDS=10
# RAG answer-generation timeout (POST /api/answer → /api/generate).
# Raise this for CPU-only / low-GPU dev boxes; gemma3 can take 30–60s per call.
OLLAMA_GENERATE_TIMEOUT_SECONDS=60

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_TEST_TEXT=사내 지식 검색 시스템 임베딩 테스트 문장입니다.
EMBEDDING_TIMEOUT_SECONDS=20

DB_HOST=localhost
DB_PORT=5433
DB_NAME=internal_ai_search
DB_USER=openlink
DB_PASSWORD=Openlink1234!@

DATA_SOURCE_SECRET_KEY=EEoBTNCTt2zWZD3CJkUMdCHwnQJWlBn3HqGPaq2nIQ4=

# --- Step 19: JWT + initial admin (CHANGE IN PRODUCTION) ---
JWT_SECRET_KEY=TwJ2AMfxim0qRNh3pN7OOA2QOWb60NY8KafDZWxAIXakfp15yjvBR4+4WJpXAFBBKdTU9roUlyeUB1OcMMmTPQ==
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720

INITIAL_ADMIN_LOGIN_ID=admin
INITIAL_ADMIN_PASSWORD=admin1234!@
INITIAL_ADMIN_NAME=Openlink
INITIAL_ADMIN_EMAIL=admin@openlink.kr
INITIAL_ADMIN_DEPARTMENT=System

PASSWORD_MIN_LENGTH=8

WEBDAV_TIMEOUT_SECONDS=15

# --- HWP tiered extraction (compose E2E) ---
HWP_EXTRACTION_STRATEGY=tiered
HWP5TXT_BIN=hwp5txt
HWP5HTML_BIN=hwp5html
HWP_PARSER_TIMEOUT_SECONDS=120
HWP_MIN_EXTRACTED_TEXT_LENGTH=50
HWP_HTML_MIN_EXTRACTED_TEXT_LENGTH=50
HWP_HTML_MIN_GAIN_RATIO=1.5
