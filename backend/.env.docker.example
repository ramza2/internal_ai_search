# Docker dev example — copy to backend/.env and replace placeholders.
# docker-compose.dev.yml uses backend/.env (not this file) for real secrets.
#
# Run compose from repo root (interpolates ${DB_PASSWORD} for the db service):
#   cp backend/.env.docker.example backend/.env
#   docker compose --env-file backend/.env -f docker-compose.dev.yml up -d
#
# Do not commit real passwords or production secrets.

# --- Database (compose internal service `db`) ---
DB_HOST=db
DB_PORT=5432
DB_NAME=internal_ai_search
DB_USER=openlink
DB_PASSWORD=CHANGE_ME

# Host port published for pgAdmin / psql from Windows (default 5434 avoids clash with host :5433)
DB_PUBLISH_PORT=5434

# --- Ollama (host machine; not inside compose) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3
OLLAMA_TIMEOUT_SECONDS=10

# --- Embedding ---
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_TEST_TEXT=사내 지식 검색 시스템 임베딩 테스트 문장입니다.
EMBEDDING_TIMEOUT_SECONDS=20

# --- Auth / secrets (placeholders only) ---
JWT_SECRET_KEY=CHANGE_ME
DATA_SOURCE_SECRET_KEY=CHANGE_ME

# --- Initial admin bootstrap (backend startup; not SQL insert) ---
INITIAL_ADMIN_LOGIN_ID=admin
INITIAL_ADMIN_PASSWORD=CHANGE_ME
INITIAL_ADMIN_NAME=Initial Admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_DEPARTMENT=System

# Compose DB E2E: set after bootstrap (gitignored in backend/.env). Used by tools/e2e_compose_verify.py
# for change-password + login; never commit real values.
# E2E_ADMIN_PASSWORD=

# --- HWP (hwp5txt / pyhwp; AGPL — legal review not complete) ---
HWP5TXT_BIN=hwp5txt
HWP_PARSER_TIMEOUT_SECONDS=120
HWP_MIN_EXTRACTED_TEXT_LENGTH=50

# --- WebDAV ---
WEBDAV_TIMEOUT_SECONDS=15

# --- DB polling worker ---
WORKER_ENABLED=false
WORKER_ID=docker-worker-1
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_HEARTBEAT_INTERVAL_SECONDS=10
WORKER_STALE_TIMEOUT_MINUTES=30
WORKER_MAX_JOBS_PER_LOOP=1

# --- FULL sync-tree emergency cap (0 = none; worker/pipeline only) ---
SYNC_TREE_EMERGENCY_MAX_ITEMS=0
