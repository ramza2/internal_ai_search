# Copy to frontend/.env (host: npm run dev). Docker Compose sets env in docker-compose.dev.yml.
#   cp frontend/.env.example frontend/.env
#
# VITE_API_BASE_URL empty = /api via Vite proxy (recommended for Docker + host dev, no CORS).
# Set http://localhost:8000 only if backend allows CORS from :5173.

VITE_API_BASE_URL=
